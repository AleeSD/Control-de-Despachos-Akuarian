# Variables de entorno requeridas. Copia este archivo a .env.local y completa los valores.
# Nunca commites .env.local al repositorio.

# URL del proyecto Supabase (Supabase → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co

# Clave pública publishable/anon (Supabase → Settings → API → Project API Keys → anon/public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Clave service_role (Supabase → Settings → API → service_role)
# ⚠️  SOLO para el servidor. Nunca expongas esta clave al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
